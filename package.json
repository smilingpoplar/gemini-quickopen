{
  "name": "gemini-quickopen",
  "version": "1.1.0",
  "description": "在 Gemini 中快捷打开当前页面并自动注入上下文",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "dev": "wxt",
    "build": "pnpm build:chrome && pnpm build:firefox",
    "build:chrome": "wxt zip -b chrome",
    "build:firefox": "wxt zip -b firefox",
    "icons:gen": "tsx tools/generate-icons.ts",
    "test": "tsx --test tests/**/*.test.ts",
    "typecheck": "wxt prepare && tsc --noEmit"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "js-yaml": "^4.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "webext-patterns": "^1.5.1"
  },
  "devDependencies": {
    "@types/firefox-webext-browser": "^120.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.2.2",
    "autoprefixer": "^10.4.21",
    "canvas": "^3.2.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "wxt": "^0.20.20"
  }
}
